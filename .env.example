# ------------------------------------------------------------
# App
# ------------------------------------------------------------
# Public site URL used for metadata, canonical URLs and Open Graph.
# Do not include a trailing slash.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"


# ------------------------------------------------------------
# Sanity CMS - Public config
# ------------------------------------------------------------
# These values are safe to expose in the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-01-01"


# ------------------------------------------------------------
# Sanity CMS - Private token
# ------------------------------------------------------------
# Read-only token used only on the server to fetch private Sanity content.
# Never expose this value with NEXT_PUBLIC_.
SANITY_API_READ_TOKEN="your_read_only_token"